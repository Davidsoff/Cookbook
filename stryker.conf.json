{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "testRunner": "command",
  "coverageAnalysis": "off",
  "reporters": ["progress", "clear-text", "html"],
  "mutate": [
    "src/lib/cooklang.ts",
    "src/lib/mealPlan.ts",
    "src/lib/shopping.ts",
    "src/lib/sourceSettings.ts",
    "src/lib/tree.ts",
    "src/lib/units.ts"
  ],
  "thresholds": {
    "high": 100,
    "low": 100,
    "break": 100
  },
  "mutator": {
    "excludedMutations": ["AssignmentExpression"]
  },
  "concurrency": 8,
  "tempDirName": "stryker-tmp",
  "commandRunner": {
    "command": "npm test"
  }
}
