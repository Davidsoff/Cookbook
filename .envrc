# >>> repo-init >>>
if [ -z "${VIRTUAL_ENV:-}" ]; then export VIRTUAL_ENV="$PWD/.venv"; fi
export PATH="$VIRTUAL_ENV/bin:$PWD/node_modules/.bin:$PATH"
export PYTHONNOUSERSITE=1
: "${PIP_CACHE_DIR:=$PWD/.pip-cache}"
export PIP_CACHE_DIR
: "${UV_CACHE_DIR:=$PWD/.uv-cache}"
export UV_CACHE_DIR
: "${npm_config_prefix:=$PWD/.npm-global}"
export npm_config_prefix
: "${npm_config_cache:=$PWD/.npm-cache}"
export npm_config_cache
# <<< repo-init <<<
